# Cloudflare Pages routing rules for 집토리 (apt-recom)
# 형식: <source> <destination> <status>

# SPA fallback for apartment deep links
# /apartment/:pnu 같은 클라이언트 라우트로 직접 진입 시 index.html 반환.
# React 가 URL 파싱해 해당 아파트 상세 모달을 오픈.
/apartment/*  /index.html  200

# NOTE: sitemap.xml 은 빌드 시점에 scripts/fetch-sitemap.mjs 가 백엔드에서 받아
# public/sitemap.xml 정적 파일로 저장한다. CF Pages `_redirects` 의 외부 host
# rewrite(200) 는 지원되지 않아 index.html 로 흡수되던 문제를 우회한다.
