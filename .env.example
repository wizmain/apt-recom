# Database
DATABASE_URL=postgresql://user@localhost:5432/apt_recom
RAILWAY_DATABASE_URL=

# Public APIs
DATA_GO_KR_API_KEY=
KAKAO_API_KEY=
KOSIS_API_KEY=

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=

# Admin (관리자 페이지 인증 토큰 — 미설정 시 관리자 API 비활성화)
ADMIN_TOKEN=
# Deployment environment (railway / local)
DEPLOYMENT_ENV=local

# ── Sentry (에러 추적 + APM, DSN 비우면 자동 비활성) ──────────────────
# 백엔드(FastAPI)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
# 프론트엔드(Vite) — VITE_ 접두어 필수
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
